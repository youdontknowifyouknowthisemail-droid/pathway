{
  "name": "pathway-desktop",
  "productName": "Pathway",
  "version": "1.0.0",
  "description": "Desktop build of Pathway.",
  "author": "Pathway",
  "main": "main.js",
  "scripts": {
    "copy": "node copy-web.mjs",
    "start": "npm run copy && electron .",
    "dist": "npm run copy && electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.pathway.app",
    "productName": "Pathway",
    "files": ["main.js", "preload.js", "app/**"],
    "win": { "target": "nsis", "icon": "app/icon-512.png" },
    "mac": { "target": "dmg", "icon": "app/icon-512.png" },
    "linux": { "target": "AppImage", "icon": "app/icon-512.png" }
  }
}
